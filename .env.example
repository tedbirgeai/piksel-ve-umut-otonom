# Yerel ortam değişkenleri — bu dosyayı .env.local olarak kopyalayın
# cp .env.example .env.local

# --- Blokzincir RPC (Alchemy — ADANMIŞ uç nokta) ---
# https://dashboard.alchemy.com → Create App → API Key
# Frontend bu anahtarı kullanır (tarayıcıya açıktır, public key olmalı):
NEXT_PUBLIC_ALCHEMY_API_KEY=
# Hardhat (sunucu/deploy) aynı anahtarı sunucu tarafında kullanır:
ALCHEMY_API_KEY=

# --- Cüzdan (Wagmi + RainbowKit) ---
# https://cloud.walletconnect.com adresinden ücretsiz alınır
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# --- Üretim Sertifikası NFT sözleşmesi (ERC-721 + ERC-2981) ---
# Sözleşmeyi dağıttıktan sonra adresini buraya yazın (boşsa demo modu çalışır)
NEXT_PUBLIC_CERTIFICATE_CONTRACT=0x0000000000000000000000000000000000000000

# --- IPFS ---
NEXT_PUBLIC_IPFS_GATEWAY=https://ipfs.io/ipfs/
IPFS_API=http://127.0.0.1:5001

# --- Ollama (yerel YZ) ---
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=llama3

# --- Sözleşme dağıtımı (Hardhat / Sepolia) ---
# DEPLOY cüzdanının özel anahtarı — ASLA paylaşmayın, repoya commit'lemeyin
PRIVATE_KEY=
# Etherscan doğrulaması için (opsiyonel)
ETHERSCAN_API_KEY=
